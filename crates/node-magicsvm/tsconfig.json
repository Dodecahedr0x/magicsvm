{
  "compilerOptions": {
    "declaration": true,
    "module": "CommonJS",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "target": "es2020",
    "noImplicitAny": true,
    "sourceMap": true,
    "outDir": "dist",
    "allowJs": true,
    "baseUrl": "magicsvm",
    "paths": {
      "litesvm": ["./"],
      "@/*": ["../*"]
    },
    "resolveJsonModule": true,
    "skipLibCheck": true
  },
  "include": ["magicsvm/**/*"]
}
